# Copy this file to .env and fill in local-only paths.
# Do not commit .env because it can contain private research data paths.

KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=29092
KAFKA_UI_PORT=8080

# Required: root folder containing date/laser_a and date/laser_b CSV folders.
DATA_DIR=

# Required later: root folder for Spark/Parquet/checkpoint/model outputs.
STORAGE_DIR=

# PostgreSQL (host access)
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=welding_drift
POSTGRES_USER=welding
POSTGRES_PASSWORD=<set-local-password>
# PostgreSQL (container-to-container access via docker network)
POSTGRES_HOST_CONTAINER=postgres

# Spark (host access)
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=18080
SPARK_WORKER_UI_PORT=18081
SPARK_MASTER=local[*]

# Airflow reserved ports (service can be added later)
AIRFLOW_WEBSERVER_PORT=18088
AIRFLOW_FLOWER_PORT=15555
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=<set-local-password>

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<set-local-password>
KAFKA_EXPORTER_PORT=9308
POSTGRES_EXPORTER_PORT=9187
CADVISOR_PORT=8088
NODE_EXPORTER_PORT=9100

# Session 7 (API/Frontend)
API_PORT=8001
FRONTEND_PORT=8501
API_BASE_URL=http://api:8000

# Optional producer settings
TOPIC_RAW=welding.raw.v1
TOPIC_RAW_LASER_A=welding.raw.laser_a.v1
TOPIC_RAW_LASER_B=welding.raw.laser_b.v1
CHUNK_SIZE=5000
SAMPLE_RATE_HZ=25000
KAFKA_COMPRESSION=gzip

# Ingest DAG runtime options
PRODUCER_IMAGE=welding-kafka-submission-producer:latest
NETWORK_NAME=welding-kafka-submission_welding-net
REPLAY_TARGET_PRODUCTS_TOTAL=0

# Batch decision / validation
SPARK_BATCH_CPD_THRESHOLD=0.35
SEGMENT_DRIFT_THRESHOLD_LASER_A=0.62
SEGMENT_DRIFT_THRESHOLD_LASER_B=0.58
SEGMENT_MODEL_NAME_LASER_A=laser_a_drift_model
SEGMENT_MODEL_NAME_LASER_B=laser_b_drift_model
SEGMENT_MODEL_VERSION_LASER_A=v1
SEGMENT_MODEL_VERSION_LASER_B=v1
SEGMENT_INFERENCE_MS_LASER_A=14
SEGMENT_INFERENCE_MS_LASER_B=19

# Daily report mode (experiment vs production-like)
DAILY_REPORT_CATCHUP=false
DAILY_REPORT_MAX_ACTIVE_RUNS=1

# 5-min consumer health monitor lag threshold
CONSUMER_LAG_ALERT_THRESHOLD=5000

