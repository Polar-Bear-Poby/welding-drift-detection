# Copy this file to .env and fill in local-only paths.
# Do not commit .env because it can contain private research data paths.

KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=29092
KAFKA_UI_PORT=8080

# Required: root folder containing date/out and date/reflect CSV folders.
DATA_DIR=

# Required later: root folder for Spark/Parquet/checkpoint/model outputs.
STORAGE_DIR=

# PostgreSQL (host access)
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=welding_drift
POSTGRES_USER=welding
POSTGRES_PASSWORD=welding_pass

# Spark (host access)
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=18080
SPARK_WORKER_UI_PORT=18081
SPARK_MASTER=local[*]

# Airflow reserved ports (service can be added later)
AIRFLOW_WEBSERVER_PORT=18088
AIRFLOW_FLOWER_PORT=15555
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Optional producer settings
TOPIC_RAW=welding.raw.v1
CHUNK_SIZE=5000
SAMPLE_RATE_HZ=25000
KAFKA_COMPRESSION=gzip
